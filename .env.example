# Copy this file to .env and fill in your values.
#   cp .env.example .env

# --- Image versions (pinned defaults) ---
SONARQUBE_VERSION=community
POSTGRES_VERSION=17
SCANNER_VERSION=12

# --- PostgreSQL credentials ---
POSTGRES_USER=sonar
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=sonar

# --- SonarQube web port (host) ---
SONARQUBE_PORT=9000

# --- Scanner authentication ---
# Generate from SonarQube UI:  My Account -> Security -> Generate Token
# (sonar.login in sonar-project.properties is deprecated since SonarQube 8.x)
SONAR_TOKEN=squ_change_this_with_your_token
